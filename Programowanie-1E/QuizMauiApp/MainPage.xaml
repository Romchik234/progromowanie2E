<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizMauiApp.MainPage"
             xmlns:local="clr-namesapce:QuizMauiApp"
             xmlns:converters="">
             
    <ContentPage.BindingContext>
        <local:MainVievModel />
    </ContentPage.BindingContext>
        <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Label Text="{Binding NumberOfQ}" HorizontalOptions="End"/>
            <Label Text=" pytanie" FontSize="32" FontAttributes="Bold"/>
            
            <RadioButton GroupName="quiz" Content="Answer 1"/> 
            <RadioButton GroupName="quiz" Content="Answer 2"/> 
            <RadioButton GroupName="quiz" Content="Answer 3"/>
            <StackLayout Orientation="Horizontal">
                <Button Text="Sprawdz" HorizontalOptions="Start" Margin="0,0,100,0"/>
                <Button Text="Nastepne" HorizontalOptions="End" />
            </StackLayout>
            <Label Text=" ilosc prawidlowych odpowiedzi: "/>
        </VerticalStackLayout> 
    </ScrollView>

</ContentPage>
